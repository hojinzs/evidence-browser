{
  "name": "evidence-browser-root",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/api",
    "packages/cli",
    "packages/shared",
    "packages/web"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names api,web \"PORT=3001 npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm -w @evidence-browser/api run dev",
    "dev:web": "npm -w @evidence-browser/web run dev",
    "build": "npm run build:shared && npm run build:api && npm run build:web && rm -rf web && cp -R packages/web/dist web",
    "build:api": "npm -w @evidence-browser/api run build",
    "build:web": "npm -w @evidence-browser/web run build",
    "start": "npm -w @evidence-browser/api run start",
    "lint": "npm run typecheck:api && npm run typecheck:web",
    "test": "npm run test:shared && npm run test:api && npm run test:cli",
    "test:api": "npm -w @evidence-browser/api run test",
    "test:cli": "npm -w evidence-browser-cli run test",
    "build:shared": "npm -w @evidence-browser/shared run build",
    "test:shared": "npm -w @evidence-browser/shared run test",
    "typecheck:api": "npm -w @evidence-browser/api run typecheck",
    "typecheck:web": "npm -w @evidence-browser/web run typecheck",
    "build:cli": "npm -w evidence-browser-cli run build",
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "concurrently": "^9.2.1"
  }
}
