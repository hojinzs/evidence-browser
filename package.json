{
  "name": "evidence-browser-root",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "packages/api",
    "packages/cli",
    "packages/shared",
    "packages/web"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names api,web \"PORT=3001 npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm -w @evidence-browser/api run dev",
    "dev:web": "npm -w @evidence-browser/web run dev",
    "build": "npm run build:shared && npm run build:api && npm run build:web",
    "build:api": "npm -w @evidence-browser/api run build",
    "build:web": "npm -w @evidence-browser/web run build",
    "start": "npm -w @evidence-browser/api run start",
    "lint": "npm run lint:eslint && npm run typecheck",
    "lint:eslint": "npm run lint:api && npm run lint:web && npm run lint:cli && npm run lint:shared",
    "lint:api": "npm -w @evidence-browser/api run lint",
    "lint:web": "npm -w @evidence-browser/web run lint",
    "lint:cli": "npm -w evidence-browser-cli run lint",
    "lint:shared": "npm -w @evidence-browser/shared run lint",
    "test": "npm run test:shared && npm run test:api && npm run test:web && npm run test:cli",
    "test:api": "npm -w @evidence-browser/api run test",
    "test:cli": "npm -w evidence-browser-cli run test",
    "test:web": "npm -w @evidence-browser/web run test",
    "e2e:smoke": "npm run build && npm -w @evidence-browser/web run e2e:smoke",
    "build:shared": "npm -w @evidence-browser/shared run build",
    "test:shared": "npm -w @evidence-browser/shared run test",
    "typecheck": "npm run typecheck:shared && npm run typecheck:api && npm run typecheck:web && npm run typecheck:cli",
    "typecheck:shared": "npm -w @evidence-browser/shared run typecheck",
    "typecheck:api": "npm -w @evidence-browser/api run typecheck",
    "typecheck:web": "npm -w @evidence-browser/web run typecheck",
    "typecheck:cli": "npm -w evidence-browser-cli run typecheck",
    "build:cli": "npm -w evidence-browser-cli run build",
    "changeset:version": "changeset version",
    "release": "changeset publish",
    "test:coverage": "npm run test:coverage:shared && npm run test:coverage:api && npm run test:coverage:web",
    "test:coverage:api": "npm -w @evidence-browser/api run test:coverage",
    "test:coverage:web": "npm -w @evidence-browser/web run test:coverage",
    "test:coverage:shared": "npm -w @evidence-browser/shared run test:coverage"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.5.0",
    "typescript-eslint": "^8.62.1"
  }
}
