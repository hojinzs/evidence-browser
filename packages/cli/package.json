{
  "name": "evidence-browser-cli",
  "version": "0.1.1",
  "description": "CLI tool for uploading bundles to Evidence Browser",
  "license": "MIT",
  "type": "commonjs",
  "main": "./dist/index.js",
  "bin": {
    "eb": "dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node --test $(find test -type f -name '*.test.js' | sort)",
    "release": "npm publish --access public"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5"
  }
}
