{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node10",
    "outDir": "./dist",
    // Intentionally compiles imported shared sources into dist/shared so the
    // Docker image can run from packages/api/dist without a separate shared copy.
    "rootDir": "..",
    "declaration": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@evidence-browser/shared": ["../shared/src/index.ts"],
      "@evidence-browser/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "../shared/src/types/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
