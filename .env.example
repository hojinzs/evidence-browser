# Data directory (SQLite DB stored here)
DATA_DIR=./data

# Auth
AUTH_SECRET=              # openssl rand -base64 32

# Storage
STORAGE_TYPE=local         # local | s3
STORAGE_LOCAL_PATH=./data/bundles

# S3/R2 (STORAGE_TYPE=s3)
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=               # R2: https://<account>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# Cache
CACHE_TTL_MS=1800000       # 30min
CACHE_MAX_ENTRIES=50

# Limits
MAX_BUNDLE_SIZE=524288000  # 500MB
MAX_FILE_COUNT=10000

# MCP
MCP_API_KEY=               # Optional: Bearer token for /api/mcp auth
